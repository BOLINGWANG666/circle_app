<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Circle.Pages.SaveFilesPage"
             BackgroundColor="#F5F5DC"
             NavigationPage.HasNavigationBar="False">

    <Grid RowSpacing="15" ColumnSpacing="15" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
               Text="Select Save File" FontSize="36" FontAttributes="Bold" TextColor="#333333" 
               VerticalOptions="Center" HorizontalOptions="Center" />

        <Button Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2"
                Text="Back" CornerRadius="10" BackgroundColor="#333333" TextColor="White" 
                FontAttributes="Bold" Clicked="OnBackClicked" />

        <Border Grid.Row="1" Grid.RowSpan="4" Grid.Column="0" Grid.ColumnSpan="4"
                Stroke="Black" StrokeThickness="4" BackgroundColor="Transparent" Padding="10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>

            <CarouselView x:Name="SavesCarousel" HorizontalScrollBarVisibility="Never" Loop="False" PositionChanged="OnCarouselPositionChanged">
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" Padding="5">

                            <BoxView Grid.Column="0" Color="Transparent" />
                            <BoxView Grid.Column="1" Color="Transparent" />
                            <BoxView Grid.Column="2" Color="Transparent" />

                            <Border Grid.Column="0" IsVisible="{Binding IsSlot1Visible}" BackgroundColor="White" Stroke="#333333" StrokeThickness="2" Padding="5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSaveSlotTapped" CommandParameter="{Binding Slot1}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="5" VerticalOptions="Center">
                                    <Label Text="{Binding Slot1DisplayId, StringFormat='ID: {0}'}" FontSize="18" FontAttributes="Bold" TextColor="Black" HorizontalOptions="Center"/>
                                    <BoxView HeightRequest="2" Color="LightGray" Margin="0,2"/>
                                    <Label Text="{Binding Slot1.Level, StringFormat='LV: {0}'}" FontSize="14" FontAttributes="Bold" TextColor="Purple" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot1.Hp, StringFormat='HP: {0}'}" FontSize="14" FontAttributes="Bold" TextColor="#D32F2F" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot1.Atk, StringFormat='ATK: {0}'}" FontSize="14" FontAttributes="Bold" TextColor="#F57C00" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot1.Cd, StringFormat='CD: {0:F1}s'}" FontSize="14" FontAttributes="Bold" TextColor="#1976D2" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot1.Cd, StringFormat='CD: {0:F1}s'}" FontSize="14" FontAttributes="Bold" TextColor="#1976D2" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot1.DodgeChance, StringFormat='DODGE: {0:P0}'}" FontSize="14" FontAttributes="Bold" TextColor="Teal" HorizontalOptions="Center"/>
                                    
                                    <Label Text="{Binding Slot1.TimeRemaining, StringFormat='TIME: {0:F1}s'}" FontSize="14" FontAttributes="Bold" TextColor="LimeGreen" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" IsVisible="{Binding IsSlot2Visible}" BackgroundColor="White" Stroke="#333333" StrokeThickness="2" Padding="5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSaveSlotTapped" CommandParameter="{Binding Slot2}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="5" VerticalOptions="Center">
                                    <Label Text="{Binding Slot2DisplayId, StringFormat='ID: {0}'}" FontSize="18" FontAttributes="Bold" TextColor="Black" HorizontalOptions="Center"/>
                                    <BoxView HeightRequest="2" Color="LightGray" Margin="0,2"/>
                                    <Label Text="{Binding Slot2.Level, StringFormat='LV: {0}'}" FontSize="14" FontAttributes="Bold" TextColor="Purple" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot2.Hp, StringFormat='HP: {0}'}" FontSize="14" FontAttributes="Bold" TextColor="#D32F2F" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot2.Atk, StringFormat='ATK: {0}'}" FontSize="14" FontAttributes="Bold" TextColor="#F57C00" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot2.Cd, StringFormat='CD: {0:F1}s'}" FontSize="14" FontAttributes="Bold" TextColor="#1976D2" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot2.DodgeChance, StringFormat='DODGE: {0:P0}'}" FontSize="14" FontAttributes="Bold" TextColor="Teal" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot2.TimeRemaining, StringFormat='TIME: {0:F1}s'}" FontSize="14" FontAttributes="Bold" TextColor="LimeGreen" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="2" IsVisible="{Binding IsSlot3Visible}" BackgroundColor="White" Stroke="#333333" StrokeThickness="2" Padding="5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSaveSlotTapped" CommandParameter="{Binding Slot3}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="5" VerticalOptions="Center">
                                    <Label Text="{Binding Slot3DisplayId, StringFormat='ID: {0}'}" FontSize="18" FontAttributes="Bold" TextColor="Black" HorizontalOptions="Center"/>
                                    <BoxView HeightRequest="2" Color="LightGray" Margin="0,2"/>
                                    <Label Text="{Binding Slot3.Level, StringFormat='LV: {0}'}" FontSize="14" FontAttributes="Bold" TextColor="Purple" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot3.Hp, StringFormat='HP: {0}'}" FontSize="14" FontAttributes="Bold" TextColor="#D32F2F" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot3.Atk, StringFormat='ATK: {0}'}" FontSize="14" FontAttributes="Bold" TextColor="#F57C00" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot3.Cd, StringFormat='CD: {0:F1}s'}" FontSize="14" FontAttributes="Bold" TextColor="#1976D2" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot3.DodgeChance, StringFormat='DODGE: {0:P0}'}" FontSize="14" FontAttributes="Bold" TextColor="Teal" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Slot3.TimeRemaining, StringFormat='TIME: {0:F1}s'}" FontSize="14" FontAttributes="Bold" TextColor="LimeGreen" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                        </Grid>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>
        </Border>

        <Label x:Name="WarningLabel"
               Text="Please select a file"
               TextColor="Red"
               FontSize="20"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               VerticalOptions="End" 
               Margin="0,0,0,10"
               IsVisible="False" 
               Grid.Row="3" Grid.Column="4" Grid.ColumnSpan="2" />

        <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                Text="&lt;" FontAttributes="Bold" FontSize="28" Padding="0"
                BackgroundColor="#E0E0E0" TextColor="Black" CornerRadius="10" Margin="5,0"
                Clicked="OnPrevSaveClicked" />

        <Button Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2"
                Text="&gt;" FontAttributes="Bold" FontSize="28" Padding="0"
                BackgroundColor="#E0E0E0" TextColor="Black" CornerRadius="10" Margin="5,0"
                Clicked="OnNextSaveClicked" />

        <Button Grid.Row="4" Grid.Column="4" Grid.ColumnSpan="2"
                Text="Load" FontAttributes="Bold" FontSize="18" CornerRadius="10" Margin="5,0"
                BackgroundColor="#4CAF50" TextColor="White" Clicked="OnLoadClicked" />

        <Button Grid.Row="5" Grid.Column="4" Grid.ColumnSpan="2"
                Text="Delete" FontAttributes="Bold" FontSize="18" CornerRadius="10" Margin="5,0"
                BackgroundColor="#F44336" TextColor="White" Clicked="OnDeleteClicked" />
    </Grid>
</ContentPage>