<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Circle.Pages.ChooseCharacter"
             BackgroundColor="#F5F5DC"
             NavigationPage.HasNavigationBar="False"            
             NavigationPage.HasBackButton="False">

    <Grid RowDefinitions="*,*,*,*,*,*,*,*,*,*" 
          ColumnDefinitions="*,*,*,*,*,*,*,*,*,*" 
          Padding="25">

        <toolkit:MediaElement x:Name="AudioPlayer" Source="tapstart.mp3" ShouldAutoPlay="False" Opacity="0" WidthRequest="1" HeightRequest="1" />

        <Button x:Name="BackButton"
                Text="&#x25C0; Back"
                TextColor="White" BackgroundColor="Black"
                CornerRadius="10"
                Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                HorizontalOptions="Start" VerticalOptions="Center"
                HeightRequest="50" WidthRequest="100"
                Clicked="OnBackClicked" />

        <Label Text="Please select your character"
               TextColor="#333333" FontSize="30" FontAttributes="Bold"
               Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="5" 
               Grid.RowSpan="2" 
               LineBreakMode="WordWrap"
               HorizontalOptions="Start" VerticalOptions="Center"
               Margin="10,0,0,0" />

        <VerticalStackLayout x:Name="StatsPanel" IsVisible="False"
                             Grid.Row="0" Grid.Column="7" Grid.ColumnSpan="3"
                             VerticalOptions="Center" HorizontalOptions="Start">
            <Label x:Name="HpLabel" TextColor="DarkGreen" FontSize="20" FontAttributes="Bold" />
            <Label x:Name="AtkLabel" TextColor="DarkRed" FontSize="20" FontAttributes="Bold" />
            <Label x:Name="CdLabel" TextColor="DarkBlue" FontSize="20" FontAttributes="Bold" />
            <Label x:Name="DodgeLabel" TextColor="Teal" FontSize="20" FontAttributes="Bold" />
        </VerticalStackLayout>

        <Border Grid.Row="2" Grid.Column="0" 
                Grid.RowSpan="5" Grid.ColumnSpan="10"
                Stroke="Black" StrokeThickness="4"
                BackgroundColor="Transparent" Margin="5">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0" />
            </Border.StrokeShape>

            <HorizontalStackLayout HorizontalOptions="Start" VerticalOptions="Start" Margin="30" Spacing="40">

                <Grid WidthRequest="130" HeightRequest="130">
                    <Border x:Name="SelectionBorder1" WidthRequest="120" HeightRequest="120" Stroke="Black" StrokeThickness="5" IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="60" />
                        </Border.StrokeShape>
                    </Border>
                    <Border x:Name="CharacterCircle" WidthRequest="90" HeightRequest="90" BackgroundColor="Gray">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="45" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCharacter1Tapped" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <Grid WidthRequest="130" HeightRequest="130">
                    <Polygon x:Name="SelectionBorder2" Points="55,0 110,110 0,110" Stroke="Black" StrokeThickness="5" Fill="Transparent" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="False" />

                    <Grid x:Name="CharacterTriangle" WidthRequest="90" HeightRequest="90" HorizontalOptions="Center" VerticalOptions="Center">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCharacter2Tapped" />
                        </Grid.GestureRecognizers>
                        <Polygon Points="45,0 90,90 0,90" Fill="DarkGray" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Grid>
                </Grid>
            </HorizontalStackLayout>
        </Border>

        <Label x:Name="WarningLabel"
               Text="You need to choose a character"
               TextColor="Red" FontSize="20" FontAttributes="Bold"
               Grid.Row="8" Grid.Column="7" Grid.ColumnSpan="3"
               HorizontalOptions="Center" VerticalOptions="End"
               IsVisible="False" />

        <Button x:Name="OkButton"
                Text="OK" BackgroundColor="#333333" TextColor="White"
                FontSize="24" CornerRadius="12"
                Grid.Row="9" Grid.Column="7" Grid.ColumnSpan="3"
                HorizontalOptions="Fill" VerticalOptions="Fill"
                Margin="5" Clicked="OnOkClicked" />
    </Grid>
</ContentPage>